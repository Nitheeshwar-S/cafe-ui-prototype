# Environment Configuration
NODE_ENV=development

# Server Configuration
PORT=5000

# MongoDB Atlas Configuration
# Replace <username>, <password>, and <cluster-url> with your actual MongoDB Atlas credentials
MONGODB_URI=mongodb+srv://fortensolutions_db_user:FortenSol@2026@cafecaffeeto.dtftoff.mongodb.net/?appName=CafeCaffeeto

# JWT Secret for admin authentication
JWT_SECRET=your-super-secure-jwt-secret-key-change-this-in-production

# API Configuration
API_BASE_URL=http://localhost:5000/api

# CORS Configuration
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# File Upload Configuration (if needed)
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/

# Email Configuration (for notifications - optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Payment Gateway Configuration (when implementing payments)
PAYMENT_GATEWAY_KEY=your-payment-gateway-key
PAYMENT_GATEWAY_SECRET=your-payment-gateway-secret

# Redis Configuration (for caching - optional)
REDIS_URL=redis://localhost:6379

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/cafe-coffeeto.log

# Security Configuration
BCRYPT_ROUNDS=10
SESSION_SECRET=your-session-secret-change-this

# Database Backup Configuration
BACKUP_PATH=backups/
BACKUP_RETENTION_DAYS=30

# Analytics Configuration
GOOGLE_ANALYTICS_ID=GA-XXXXX-XX

# Social Media Configuration
INSTAGRAM_ACCESS_TOKEN=your-instagram-token
FACEBOOK_PAGE_ID=your-facebook-page-id

# Push Notifications (optional)
FIREBASE_SERVER_KEY=your-firebase-server-key

# SMS Configuration (for order notifications)
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=CAFECOF